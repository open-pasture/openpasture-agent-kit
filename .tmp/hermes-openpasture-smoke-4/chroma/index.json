  "knowledge_greg-judy_02_actionable-lessons": {
    "category": "grazing-management",
    "content": "- Daily moves are a strong default. - Back fences matter because they protect new regrowth from immediate re-bite. - Leave more than you take when possible. - A 40-plus-day recovery window is a useful baseline, then adjust for season and growth rate.",
    "created_at": "2026-04-13T04:19:38.815725",
    "embedding_id": "knowledge_greg-judy_02_actionable-lessons",
    "entry_type": "technique",
    "farm_id": null,
