  "knowledge_universal_02_daily-movement-bias": {
    "category": "grazing-management",
    "content": "Move animals daily when the operation can support it. Frequent moves preserve selectivity, reduce reglazing pressure on fresh regrowth, and keep recovery cleaner.",
    "created_at": "2026-04-13T04:19:38.816324",
    "embedding_id": "knowledge_universal_02_daily-movement-bias",
    "entry_type": "principle",
