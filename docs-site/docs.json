        "pages": [
          "cli",
          "mcp",
          "hermes-adapter",
          "skills",
          "knowledge"
        ]
      },
      {
        "group": "Deploy And Operate",
        "pages": [
          "self-hosting",
          "hosted-cloud",
          "environment-variables",
          "troubleshooting"
        ]
      },
      {
        "group": "Build With OpenPasture",
        "pages": [
          "architecture",
          "developer-guidance",
          "changelog"
        ]
      }
    ]
  }
}
